---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageSEO from "@/components/PageSEO.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
    const collages = await getCollection("gallery");
    return collages.map((collage) => ({
        params: { slug: collage.id },
        props: { collage },
    }));
}

const { collage } = Astro.props;
const { title, description, date, photos } = collage.data;
---

<BaseLayout>
    <PageSEO slot="head" title={`${title} — Peter Tran`} />

    <main class="mx-auto max-w-5xl px-5 sm:px-6 py-16">
        <a
            href="/gallery"
            class="inline-flex items-center gap-2 text-sm text-secondary hover:text-primary transition-colors duration-200 mb-10"
        >
            ← Back to Gallery
        </a>

        <p class="text-xs uppercase tracking-[0.15em] text-secondary mb-2 font-medium">{date}</p>
        <h1 class="text-3xl font-medium text-primary mb-2">{title}</h1>
        {description && <p class="text-secondary mb-10 text-sm leading-relaxed">{description}</p>}

        {photos.length > 0 ? (
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
                {photos.map((photo, i) => (
                    <button
                        class="aspect-square overflow-hidden rounded border border-border bg-cellbg group"
                        data-photo={photo}
                        data-index={String(i)}
                        aria-label={`View photo ${i + 1}`}
                    >
                        <img
                            src={photo}
                            alt={`${title} — photo ${i + 1}`}
                            class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                            loading="lazy"
                        />
                    </button>
                ))}
            </div>
        ) : (
            <div class="border border-border rounded-lg p-10 text-center text-secondary text-sm">
                <p class="mb-2 font-medium text-primary">No photos yet</p>
                <p>
                    Add image paths to the
                    <code class="font-mono text-xs bg-cellbg px-1 py-0.5 rounded mx-1">photos</code>
                    array in
                    <code class="font-mono text-xs bg-cellbg px-1 py-0.5 rounded mx-1">src/content/gallery/{collage.id}.yml</code>
                    and drop the files in
                    <code class="font-mono text-xs bg-cellbg px-1 py-0.5 rounded mx-1">/public/gallery/{collage.id}/</code>.
                </p>
            </div>
        )}
    </main>

    <!-- Lightbox -->
    <div
        id="lightbox"
        class="fixed inset-0 z-50 bg-black/90 hidden items-center justify-center"
        role="dialog"
        aria-modal="true"
    >
        <button
            id="lb-close"
            class="absolute top-5 right-5 text-white/60 hover:text-white text-3xl leading-none"
            aria-label="Close"
        >✕</button>
        <button
            id="lb-prev"
            class="absolute left-5 top-1/2 -translate-y-1/2 text-white/60 hover:text-white text-4xl leading-none px-2"
            aria-label="Previous"
        >‹</button>
        <button
            id="lb-next"
            class="absolute right-5 top-1/2 -translate-y-1/2 text-white/60 hover:text-white text-4xl leading-none px-2"
            aria-label="Next"
        >›</button>
        <img
            id="lb-img"
            src=""
            alt=""
            class="max-h-[88vh] max-w-[88vw] object-contain rounded"
        />
        <p
            id="lb-counter"
            class="absolute bottom-5 left-1/2 -translate-x-1/2 text-white/40 text-xs tabular-nums"
        ></p>
    </div>
</BaseLayout>

<script>
    const photos = [...document.querySelectorAll<HTMLButtonElement>("[data-photo]")].map(
        (b) => b.dataset.photo!
    );

    const lightbox  = document.getElementById("lightbox")!;
    const img       = document.getElementById("lb-img") as HTMLImageElement;
    const counter   = document.getElementById("lb-counter")!;
    let current     = 0;

    function show(index: number) {
        current = ((index % photos.length) + photos.length) % photos.length;
        img.src = photos[current];
        counter.textContent = `${current + 1} / ${photos.length}`;
        lightbox.classList.remove("hidden");
        lightbox.classList.add("flex");
    }

    function close() {
        lightbox.classList.add("hidden");
        lightbox.classList.remove("flex");
    }

    document.querySelectorAll<HTMLButtonElement>("[data-photo]").forEach((btn, i) => {
        btn.addEventListener("click", () => show(i));
    });

    document.getElementById("lb-close")!.addEventListener("click", close);
    document.getElementById("lb-prev")!.addEventListener("click", () => show(current - 1));
    document.getElementById("lb-next")!.addEventListener("click", () => show(current + 1));

    lightbox.addEventListener("click", (e) => {
        if (e.target === lightbox) close();
    });

    document.addEventListener("keydown", (e) => {
        if (lightbox.classList.contains("hidden")) return;
        if (e.key === "Escape")      close();
        if (e.key === "ArrowLeft")   show(current - 1);
        if (e.key === "ArrowRight")  show(current + 1);
    });
</script>
