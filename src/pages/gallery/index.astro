---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageSEO from "@/components/PageSEO.astro";
import { getCollection } from "astro:content";

const collages = await getCollection("gallery");
---

<BaseLayout>
    <PageSEO slot="head" title="Gallery — Peter Tran" />

    <main class="mx-auto max-w-5xl px-5 sm:px-6 py-16">
        <p class="text-xs uppercase tracking-[0.15em] text-secondary mb-2 font-medium">Visual</p>
        <h1 class="text-3xl font-medium text-primary mb-12">Gallery</h1>

        {collages.length > 0 ? (
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                {collages.map((collage) => (
                    <a href={`/gallery/${collage.id}`} class="group block">
                        <div class="aspect-[4/3] overflow-hidden rounded-lg border border-border bg-cellbg mb-3">
                            {collage.data.cover ? (
                                <img
                                    src={collage.data.cover}
                                    alt={collage.data.title}
                                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                                />
                            ) : (
                                <div class="w-full h-full flex items-center justify-center text-secondary text-sm">
                                    No cover yet
                                </div>
                            )}
                        </div>
                        <h2 class="font-medium text-primary group-hover:text-accent transition-colors duration-200">
                            {collage.data.title}
                        </h2>
                        {collage.data.description && (
                            <p class="text-sm text-secondary mt-1">{collage.data.description}</p>
                        )}
                        <div class="flex items-center gap-3 mt-2 text-xs text-secondary">
                            <span>{collage.data.date}</span>
                            {collage.data.photos.length > 0 && (
                                <span>· {collage.data.photos.length} photos</span>
                            )}
                        </div>
                    </a>
                ))}
            </div>
        ) : (
            <p class="text-secondary text-sm">
                No collages yet. Add a <code class="font-mono text-xs bg-cellbg px-1 py-0.5 rounded">.yml</code> file to
                <code class="font-mono text-xs bg-cellbg px-1 py-0.5 rounded">src/content/gallery/</code> to get started.
            </p>
        )}
    </main>
</BaseLayout>
