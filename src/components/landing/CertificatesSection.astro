---
export interface Props {
    headingStyle: string;
}

const { headingStyle } = Astro.props;

interface Certificate {
    name: string;
    issuer: string;
    issued: string;
    skills: string[];
}

const certs: Certificate[] = [
    {
        name: "Intermediate Cybersecurity",
        issuer: "CodePath",
        issued: "Aug 2025",
        skills: ["Security Incident Response", "Splunk", "Wireshark", "Network Security"],
    },
    {
        name: "JPMorgan Chase & Co. Software Engineering Job Simulation",
        issuer: "Forage",
        issued: "June 2025",
        skills: ["Project Setup", "Kafka Integration", "H2 Integration", "REST APIs"],
    },
    {
        name: "Entrepreneurship and Small Business",
        issuer: "Certiport - A Pearson VUE Business",
        issued: "May 2022",
        skills: [],
    },
    {
        name: "Microsoft Office Specialist: Word 2016",
        issuer: "Microsoft",
        issued: "Dec 2021",
        skills: [],
    },
];
---

<section id="certificates" class="mt-0 py-8">
    <div class="px-5 sm:px-6 mx-auto max-w-4xl">
        <h2 class={headingStyle}>Certificates</h2>

        <div>
            {certs.map((cert) => (
                <div class="py-5 flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2">
                    <div class="flex-1">
                        <p class="font-medium text-primary text-sm">{cert.name}</p>
                        <p class="text-sm text-secondary mt-0.5">{cert.issuer}</p>
                        {cert.skills.length > 0 && (
                            <div class="mt-2 flex flex-wrap gap-1.5">
                                {cert.skills.map((s) => (
                                    <span class="text-xs text-secondary border border-border px-2 py-0.5 rounded font-mono">{s}</span>
                                ))}
                            </div>
                        )}
                    </div>
                    <span class="text-xs text-secondary/70 whitespace-nowrap shrink-0 sm:text-right mt-0.5">
                        Issued {cert.issued}
                    </span>
                </div>
            ))}
        </div>
    </div>
</section>
