---
export interface Props {
    headingStyle: string;
}

const { headingStyle } = Astro.props;

interface SkillCategory {
    label: string;
    items: string[];
}

const categories: SkillCategory[] = [
    {
        label: "Languages",
        items: ["C", "C++", "Python", "Java", "JavaScript", "TypeScript", "NoSQL (MongoDB)", "SQL (SQLite3, PostgreSQL)"],
    },
    {
        label: "Frameworks",
        items: ["SpringBoot", "FastAPI", "React.js", "Tailwind CSS", "Flask", "Express.js", "Next.js"],
    },
    {
        label: "Tools & Concepts",
        items: ["Git", "Docker", "Azure", "AWS", "Linux", "HTTP", "REST APIs", "Kafka", "GitHub Actions"],
    },
    {
        label: "Libraries",
        items: ["PyTorch", "TensorFlow", "OpenCV", "scikit-learn", "NumPy", "pandas"],
    },
];
---

<section id="skills" class="mt-0 py-8">
    <div class="px-5 sm:px-6 mx-auto max-w-4xl">
        <h2 class={headingStyle}>Skills</h2>

        <div class="space-y-6">
            {categories.map((cat) => (
                <div class="flex flex-col sm:flex-row sm:items-start gap-3 sm:gap-6">
                    <p class="text-xs font-bold uppercase tracking-widest text-secondary whitespace-nowrap w-36 shrink-0 pt-0.5">
                        {cat.label}
                    </p>
                    <div class="flex flex-wrap gap-2">
                        {cat.items.map((item) => (
                            <span class="text-sm text-primary/80 border border-border px-3 py-1 rounded font-mono">
                                {item}
                            </span>
                        ))}
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
