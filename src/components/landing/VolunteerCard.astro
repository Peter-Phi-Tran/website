---
import { Image } from "astro:assets";

import adobeLogo from "@/content/volunteer/adobe.png";
import awsLogo from "@/content/volunteer/awslogo.png";
import saseLogo from "@/content/volunteer/utasase.jpg";
import acmLogo from "@/content/volunteer/acm.png";
import vbLogo from "@/content/volunteer/utamvb.jpg";

interface VolunteerRole {
    org: string;
    role: string;
    duration: string;
    logo?: ImageMetadata;
}

const roles: VolunteerRole[] = [
    { org: "Adobe",           logo: adobeLogo, role: "Campus Ambassador",           duration: "Aug 2025 – Present" },
    { org: "AWS",             logo: awsLogo,   role: "Student Builder Group Leader", duration: "Nov 2025 – Present" },
    { org: "UTA SASE",        logo: saseLogo,  role: "Event Coordinator",           duration: "Fall 2025" },
    { org: "UTA SASE",        logo: saseLogo,  role: "Treasurer",                   duration: "Spring 2026" },
    { org: "ACM",             logo: acmLogo,   role: "Outreach Officer",            duration: "Jan 2026 – May 2026" },
    { org: "Club Volleyball", logo: vbLogo,    role: "Media Team",                  duration: "Men's & Women's" },
];
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {roles.map((r) => (
        <div class="border border-border rounded-xl px-5 py-4 flex flex-col gap-2">
            <div class="flex items-center gap-3">
                {r.logo ? (
                    <Image
                        src={r.logo}
                        alt={`${r.org} logo`}
                        width={32}
                        height={32}
                        densities={[1.5, 2]}
                        class="size-8 object-contain rounded"
                    />
                ) : (
                    <span class="size-8 rounded bg-border flex items-center justify-center text-xs font-bold text-secondary shrink-0">
                        {r.org[0]}
                    </span>
                )}
                <span class="text-sm font-bold tracking-wide text-primary">{r.org}</span>
            </div>
            <span class="text-sm text-secondary pl-11">{r.role}</span>
            <span class="text-xs text-secondary/60 pl-11">{r.duration}</span>
        </div>
    ))}
</div>